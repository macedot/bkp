# Deny all (whitelist mode)
*

# Allow directories to be traversed
!*/

# Allow only what this repo needs
!.gitignore
!README.md
!LICENSE
!Makefile
!src/
!src/**
!vendor/
!vendor/**
!testdata/
!testdata/**
!.github/
!.github/**

# Still deny build artifacts / junk inside allowed trees
src/**/*.o
src/**/*.obj
vendor/**/*.o
vendor/**/*.obj
vendor/zstd/lib/obj/
vendor/zstd/lib/libzstd.a
vendor/zstd/lib/libzstd.so*
vendor/zstd/lib/libzstd.dylib*
*.o
*.obj
*.lib
bkp
bkp.exe
*.zip
*.dylib
*.so
*.a
.DS_Store
